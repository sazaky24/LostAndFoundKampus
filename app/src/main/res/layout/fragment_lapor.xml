<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F9"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF5722"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Formulir Laporan"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih status dan isi detail barang di bawah ini"
            android:textColor="#FFCCBC"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Foto Barang (Opsional)"
                android:textColor="#212121"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_tambah_foto"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_preview"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#757575" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tambah Foto"
                        android:textColor="#757575"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Laporan *"
                android:textColor="#212121"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_hilang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kehilangan"
                    android:textColor="#D84315"
                    android:checked="true"
                    android:layout_marginEnd="16dp"/>

                <RadioButton
                    android:id="@+id/rb_temuan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menemukan"
                    android:textColor="#2E7D32"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Barang *"
                android:textColor="#212121"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_nama_barang"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_search_white"
                android:hint="Contoh: Dompet kulit coklat"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lokasi Terakhir Terlihat/Ditemukan *"
                android:textColor="#212121"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_lokasi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_search_white"
                android:drawableStart="@android:drawable/ic_menu_mylocation"
                android:drawablePadding="12dp"
                android:hint="Contoh: Gedung Fakultas Teknik"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deskripsi Tambahan"
                android:textColor="#212121"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_search_white"
                android:gravity="top|start"
                android:hint="Ceritakan ciri-ciri atau informasi tambahan tentang barang..."
                android:importantForAutofill="no"
                android:inputType="textMultiLine"
                android:padding="16dp" />

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#FF5722"
                android:text="Kirim Laporan"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>